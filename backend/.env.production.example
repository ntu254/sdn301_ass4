# Environment Variables for Backend Production

# Server
PORT=5000
NODE_ENV=production

# Database - Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/quiz_app?retryWrites=true&w=majority

# JWT - CHANGE THIS to a strong random string (min 32 characters)
JWT_SECRET=please_change_this_to_a_very_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Instructions:
# 1. Copy this file to .env
# 2. Replace MONGO_URI with your MongoDB Atlas connection string
# 3. Generate a strong JWT_SECRET (you can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# 4. Never commit .env file to Git!
